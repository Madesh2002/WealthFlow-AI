rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    
    function isValidUserProfile(data) {
      return data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 100
          && data.email is string && data.email.size() <= 200
          && (!('phone' in data) || (data.phone is string && data.phone.size() <= 20));
    }

    function isValidExpense(data) {
      return data.amount is number && data.amount > 0
          && data.category in ['Food', 'Transport', 'Shopping', 'Entertainment', 'Bills', 'Other']
          && data.description is string && data.description.size() <= 500
          && data.userId == request.auth.uid
          && data.date is timestamp;
    }

    function isValidBudget(data) {
      return data.category is string && data.category.size() <= 50
          && data.amount is number && data.amount >= 0
          && data.userId == request.auth.uid
          && (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidSavingsGoal(data) {
      return data.monthlyIncome is number && data.monthlyIncome >= 0
          && data.targetSavings is number && data.targetSavings >= 0
          && data.userId == request.auth.uid
          && (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidAlert(data) {
      return data.message is string && data.message.size() <= 1000
          && data.type in ['info', 'warning', 'error']
          && data.userId == request.auth.uid
          && data.timestamp is timestamp;
    }

    function isValidPreferences(data) {
      return (!('pushEnabled' in data) || data.pushEnabled is bool)
          && (!('emailEnabled' in data) || data.emailEnabled is bool);
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserProfile(incoming());
    }

    match /preferences/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidPreferences(incoming());
    }

    match /alerts/{alertId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidAlert(incoming());
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /expenses/{expenseId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidExpense(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidExpense(incoming())
                    && incoming().userId == existing().userId
                    && incoming().date == existing().date;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /budgets/{budgetId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && isValidBudget(incoming());
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /savingsGoals/{goalId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isSignedIn() && isValidSavingsGoal(incoming());
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
